###############################################################################
# Perfulandia SPA — ms-usuarios (puerto 8081)
# Usuarios de prueba (data.sql):
#   admin@perfulandia.cl   / Pass1234
#   gerente@perfulandia.cl / Pass1234
#   empleado@perfulandia.cl / Pass1234
#   logistica@perfulandia.cl / Pass1234
#   cliente@gmail.com      / Pass1234
###############################################################################

@base_url = http://localhost:8081


# ═══════════════════════════════════════════════════════════════════════════════
#  AUTH — Endpoints públicos
# ═══════════════════════════════════════════════════════════════════════════════

### HU-01 | Registro Cliente
# Esperado: 201
POST {{base_url}}/api/auth/registro
Content-Type: application/json

{
  "nombre": "Andrea Vega",
  "email": "andrea.vega_{{$timestamp}}@gmail.com",
  "password": "AndreaV123",
  "direccion": "Av. Las Condes 456, Santiago"
}


### HU-01b | Registro — Email duplicado
# Esperado: 400
POST {{base_url}}/api/auth/registro
Content-Type: application/json

{
  "nombre": "Andrea Copia",
  "email": "andrea.vega_{{$timestamp}}@gmail.com",
  "password": "Carlos123",
  "direccion": "Otra direccion 456"
}


### HU-01c | Registro — Password sin mayuscula
# Esperado: 400
POST {{base_url}}/api/auth/registro
Content-Type: application/json

{
  "nombre": "Test",
  "email": "test@test.com",
  "password": "sinmayuscula1",
  "direccion": "Direccion test"
}


### HU-02 | Login Admin
# @name login_admin
# Esperado: 200
POST {{base_url}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@perfulandia.cl",
  "password": "Pass1234"
}


### HU-02b | Login Cliente
# @name login_cliente
# Esperado: 200
POST {{base_url}}/api/auth/login
Content-Type: application/json

{
  "email": "cliente@gmail.com",
  "password": "Pass1234"
}


### HU-02c | Login — Credenciales incorrectas
# Esperado: 401
POST {{base_url}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@perfulandia.cl",
  "password": "ContrasenaMala1"
}


### HU-44a | Recuperar Password (usuario recien registrado)
# @name recuperar_password
# Esperado: 200
# Usa el email del usuario creado en HU-01, no un seed, para no alterar contraseñas fijas
POST {{base_url}}/api/auth/recuperar
Content-Type: application/json

{
  "correo": "andrea.vega_{{$timestamp}}@gmail.com"
}


### HU-44b | Restablecer Password
# Esperado: 200
POST {{base_url}}/api/auth/restablecer
Content-Type: application/json

{
  "token": "{{recuperar_password.response.body}}",
  "nuevaContrasena": "NuevaClave1"
}


# ═══════════════════════════════════════════════════════════════════════════════
#  PERFIL — Requiere autenticacion
# ═══════════════════════════════════════════════════════════════════════════════

### HU-03 | Obtener Perfil (con token admin)
# Esperado: 200
GET {{base_url}}/api/usuarios/perfil
Authorization: Bearer {{login_admin.response.body.token}}


### HU-03b | Obtener Perfil — Sin token
# Esperado: 403
GET {{base_url}}/api/usuarios/perfil


### HU-04 | Actualizar Perfil (con token cliente)
# Esperado: 200
PUT {{base_url}}/api/usuarios/perfil
Content-Type: application/json
Authorization: Bearer {{login_cliente.response.body.token}}

{
  "nombre": "Cliente Actualizado",
  "direccion": "Nueva Direccion 789",
  "nuevoMetodoPago": "1234-5678-9012-3456"
}


# ═══════════════════════════════════════════════════════════════════════════════
#  ADMIN — Solo rol ADMIN
# ═══════════════════════════════════════════════════════════════════════════════

### HU-06 | Listar Usuarios
# Esperado: 200
GET {{base_url}}/api/usuarios?page=0&size=10
Authorization: Bearer {{login_admin.response.body.token}}


### HU-06b | Listar Usuarios — Filtro por rol EMPLEADO
# Esperado: 200
GET {{base_url}}/api/usuarios?rol=EMPLEADO
Authorization: Bearer {{login_admin.response.body.token}}


### HU-05 | Crear Usuario (ADMIN)
# @name crear_empleado
# Esperado: 201
POST {{base_url}}/api/usuarios
Content-Type: application/json
Authorization: Bearer {{login_admin.response.body.token}}

{
  "nombre": "Pedro Lopez",
  "email": "pedro.lopez_{{$timestamp}}@perfulandia.cl",
  "rol": "EMPLEADO"
}


### HU-07 | Actualizar Usuario (ADMIN)
# Esperado: 200
PUT {{base_url}}/api/usuarios/{{crear_empleado.response.body.id}}
Content-Type: application/json
Authorization: Bearer {{login_admin.response.body.token}}

{
  "nombre": "Pedro Modificado",
  "email": "pedro.lopez_{{$timestamp}}@perfulandia.cl",
  "rol": "LOGISTICA"
}


### HU-08 | Desactivar Usuario (ADMIN)
# Esperado: 200
DELETE {{base_url}}/api/usuarios/{{crear_empleado.response.body.id}}
Authorization: Bearer {{login_admin.response.body.token}}


### HU-08b | Desactivar Usuario — Ya inactivo
# Esperado: 400
DELETE {{base_url}}/api/usuarios/{{crear_empleado.response.body.id}}
Authorization: Bearer {{login_admin.response.body.token}}


### HU-45 | Cerrar Sesion (invalida token admin)
# Esperado: 200
POST {{base_url}}/api/auth/logout
Content-Type: application/json
Authorization: Bearer {{login_admin.response.body.token}}
