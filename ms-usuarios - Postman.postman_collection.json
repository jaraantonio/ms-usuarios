          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/usuarios/roles/GERENTE/permisos", "host": ["{{baseUrl}}"], "path": ["api", "usuarios", "roles", "GERENTE", "permisos"] } },
